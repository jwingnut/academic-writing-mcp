# Academic Writing MCP — Machine-Specific Configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── LibreOffice (required) ────────────────────────────────────────────────────
# URL of the LibreOffice MCP extension running in your VirtualBox VM.
# The IP is your WSL2 gateway to Windows (check: ip route show default | awk '{print $3}').
# VirtualBox NAT port forwarding + netsh portproxy must be set up (see setup-windows.ps1).
LIBREOFFICE_URL=http://172.28.32.1:8765

# ── Zotero — Local API (default, no key needed) ───────────────────────────────
# Override the auto-detected Windows host IP if needed.
# Leave unset to auto-detect from WSL default route.
# ZOTERO_HOST=172.28.32.1

# ── Zotero — Web API (alternative to local API) ───────────────────────────────
# Set both to use the Zotero cloud API instead of the local desktop API.
# Get your API key at: https://www.zotero.org/settings/keys
# Your library/user ID is the number in your Zotero profile URL.
# ZOTERO_API_KEY=your_api_key_here
# ZOTERO_LIBRARY_ID=your_numeric_user_id_here

# ── FastMCP ───────────────────────────────────────────────────────────────────
# Suppress the startup banner so MCP clients don't misread stderr as an error.
FASTMCP_SHOW_SERVER_BANNER=false
